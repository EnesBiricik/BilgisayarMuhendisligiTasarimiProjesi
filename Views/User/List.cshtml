@model IEnumerable<UserListViewModel>
@using BilgisayarMuhendisligiTasarimi.Data.Entities
@using System.Security.Claims
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
    var currentUserRole = User.FindFirstValue(ClaimTypes.Role);
}

@section Links {
        <link rel="stylesheet" href="~/dashboard/css/plugins/dataTables.bootstrap5.min.css">
<style>
        .custom-tooltip .tooltip-inner {
            background-color: #333;
            color: #fff;
            padding: 8px 12px;
            font-size: 14px;
            border-radius: 4px;
        }
        .custom-tooltip .tooltip-arrow::before {
            border-top-color: #333;
        }
        button:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }
        .page-header-title .btn-link {
            padding: 0;
            color: #0dcaf0;
            text-decoration: none;
        }
        .page-header-title .btn-link:hover {
            color: #0aa2c0;
        }
        .help-modal-icon {
            width: 30px;
            text-align: center;
        }
    </style>}

@section breadcrumb {
    <div class="col-md-12">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Anasayfa</a></li>
            <li class="breadcrumb-item">
                <a href="javascript: void(0)">Kullanıcılar</a>
            </li>
            <li class="breadcrumb-item" aria-current="page">Kullanıcılar</li>
        </ul>
    </div>
    <div class="col-md-12">
        <div class="page-header-title d-flex align-items-center">
            <h2 class="mb-0">Kullanıcı Listesi</h2>
            <button type="button" class="btn btn-link ms-2" data-bs-toggle="modal" data-bs-target="#helpModal">
                <i class="fas fa-question-circle fa-lg text-info"></i>
            </button>
        </div>
    </div>
}

@Html.AntiForgeryToken()

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="float-right">
                            <a href="@Url.Action("Create", "User")" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Yeni Kullanıcı Ekle
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="usersTable" class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th>Ad Soyad</th>
                                        <th>Email</th>
                                        <th>Rol</th>
                                        <th>Son Giriş</th>
                                        <th>Durum</th>
                                        <th style="width: 200px">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var isSameRole = currentUserRole == item.RoleName;
                                        var isDisabled = isSameRole ? "disabled" : "";
                                        var disabledTitle = isSameRole ? "Kendinizle aynı role sahip kullanıcılar üzerinde işlem yapamazsınız" : "";

                                        <tr data-id="@item.Id" 
                                            data-name="@item.Name"
                                            data-isActive="@(item.IsActive.ToString().ToLower())"
                                            data-isLocked="@(item.IsLocked.ToString().ToLower())"
                                            data-email="@item.Email"
                                            data-role="@item.RoleName"
                                            data-last-login="@(item.LastLoginAt?.ToString("dd.MM.yyyy HH:mm"))"
                                            data-last-login-ip="@item.LastLoginIp"
                                            data-failed-login="@item.FailedLoginCount"
                                            data-lockout-end="@(item.LockoutEnd?.ToString("dd.MM.yyyy HH:mm"))">
                                            <td>@item.Name</td>
                                            <td>@item.Email</td>
                                            <td id="role-cell-@item.Id">
                                                @{
                                                    var badgeClass = item.RoleId switch
                                                    {
                                                        (int)RoleEnum.SuperAdmin => "badge bg-danger",
                                                        (int)RoleEnum.Admin => "badge bg-primary",
                                                        _ => "badge bg-secondary"
                                                    };
                                                }
                                                <span class="@badgeClass role-badge">@item.RoleName</span>
                                            </td>
                                            <td>@(item.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                            <td class="status-cell">
                                                @{
                                                    // İlk span: Aktif/Pasif durumu
                                                    var activeClass = item.IsActive ? "bg-success" : "bg-secondary";
                                                    var activeText = item.IsActive ? "Aktif" : "Pasif";
                                                    <span class="badge @activeClass status-active-badge">@activeText</span>
                                                    
                                                    // İkinci span: Kilitli durumu
                                                    if (item.IsLocked)
                                                    {
                                                        <span class="badge bg-danger status-locked-badge">Kilitli</span>
                                                    }
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#userDetailModal" 
                                                        onclick="showUserDetail(this)"
                                                        data-bs-custom-class="custom-tooltip"
                                                        data-bs-title="Kullanıcı detaylarını görüntüle">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                @if (item.RoleId != (int)RoleEnum.SuperAdmin)
                                                { 
                                                    <button type="button" class="btn btn-info btn-sm" 
                                                            onclick="openEditRoleModal(this)" 
                                                            data-bs-custom-class="custom-tooltip"
                                                            data-bs-title="Kullanıcı rolünü düzenle"
                                                            @isDisabled title="@disabledTitle">
                                                        <i class="fas fa-user-edit"></i>
                                                    </button>
                                                    <button onclick="toggleStatus(@item.Id)" class="btn @(item.IsActive ? "btn-warning" : "btn-success") btn-sm"
                                                            data-bs-custom-class="custom-tooltip"
                                                            data-bs-title="@(item.IsActive ? "Kullanıcıyı pasife al" : "Kullanıcıyı aktife al")"
                                                            @isDisabled title="@disabledTitle">
                                                        <i class="fas fa-@(item.IsActive ? "lock" : "lock-open")"></i>
                                                    </button>
                                                    <button onclick="resetLoginAttempts(@item.Id)" class="btn btn-secondary btn-sm"
                                                            data-bs-custom-class="custom-tooltip"
                                                            data-bs-title="Giriş denemelerini sıfırla"
                                                            @isDisabled title="@disabledTitle">
                                                        <i class="fas fa-history"></i>
                                                    </button>
                                                    <button onclick="deleteItem(@item.Id)" class="btn btn-danger btn-sm"
                                                            data-bs-custom-class="custom-tooltip"
                                                            data-bs-title="Kullanıcıyı sil"
                                                            @isDisabled title="@disabledTitle">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                   
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Kullanıcı Detay Modal -->
<div class="modal fade" id="userDetailModal" tabindex="-1" role="dialog" aria-labelledby="userDetailModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userDetailModalTitle">Kullanıcı Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="fw-bold">Ad Soyad:</label>
                            <p id="userName"></p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Email:</label>
                            <p id="userEmail"></p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Rol:</label>
                            <p id="userRole"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="fw-bold">Son Giriş:</label>
                            <p id="userLastLogin"></p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Son Giriş IP:</label>
                            <p id="userLastLoginIp"></p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Başarısız Giriş:</label>
                            <p id="userFailedLogin"></p>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Kilit Bitiş:</label>
                            <p id="userLockoutEnd"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<!-- Help Modal -->
