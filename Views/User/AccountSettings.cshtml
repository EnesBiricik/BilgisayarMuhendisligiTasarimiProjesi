@model BilgisayarMuhendisligiTasarimi.Models.UserAccountSettingsModel

@{
    ViewData["Title"] = "Hesap Ayarları";
}

@section breadcrumb {
    <div class="col-md-12">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Anasayfa</a></li>
            <li class="breadcrumb-item" aria-current="page">Hesap Ayarları</li>
        </ul>
    </div>
    <div class="col-md-12">
        <div class="page-header-title">
            <h2 class="mb-0">Hesap Ayarları</h2>
        </div>
    </div>
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12 mx-auto">
            <div class="card">
                <div class="card-body">
                    <form asp-action="AccountSettings" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label">Ad Soyad</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="control-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="CurrentPassword" class="control-label">Mevcut Şifre</label>
                            <input asp-for="CurrentPassword" class="form-control" type="password" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">Güncelle</button>
                            <a asp-action="Index" class="btn btn-secondary">İptal</a>
                            <a asp-action="UpdatePassword" class="btn btn-light-secondary">Şifremi Güncelle</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>