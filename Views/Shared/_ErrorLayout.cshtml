<!DOCTYPE html>
<html lang="tr">
<head>
    <title>@ViewData["Title"]</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=0,minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <!-- Favicon -->
    <link rel="icon" href="~/dashboard/images/favicon.svg" type="image/x-icon">
    
    <!-- Fonts -->
    <link rel="stylesheet" href="~/dashboard/fonts/inter/inter.css" id="main-font-link">
    <link rel="stylesheet" href="~/dashboard/fonts/tabler-icons.min.css">
    <link rel="stylesheet" href="~/dashboard/fonts/phosphor/duotone/style.css">
    <link rel="stylesheet" href="~/dashboard/fonts/feather.css">
    <link rel="stylesheet" href="~/dashboard/fonts/fontawesome.css">
    <link rel="stylesheet" href="~/dashboard/fonts/material.css">
    
    <!-- Template CSS -->
    <link rel="stylesheet" href="~/dashboard/css/style.css" id="main-style-link">
    <link rel="stylesheet" href="~/dashboard/css/style-preset.css">

    <style>
        .loader-bg {
            position: fixed;
            z-index: 999999;
            background: var(--bs-body-bg);
            width: 100%;
            height: 100%;
        }
        .loader-track {
            position: relative;
            left: 50%;
            top: 50%;
            width: 170px;
            height: 2px;
            margin-left: -85px;
            margin-top: -1px;
            background-color: var(--bs-border-color);
            border-radius: 4px;
        }
        .loader-fill {
            position: absolute;
            left: 0;
            top: 0;
            width: 50%;
            height: 100%;
            background-color: var(--bs-primary);
            border-radius: 4px;
            animation: loader 1s ease-in-out infinite;
        }
        @@keyframes loader {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(200%); }
        }
    </style>
</head>
<body>
    <!-- Pre-loader -->
    <div class="loader-bg">
        <div class="loader-track">
            <div class="loader-fill"></div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="maintenance-block">
        <div class="container">
            <div class="row">
                <div class="col-sm-12">
                    <div class="card error-card">
                        <div class="card-body">
                            @RenderBody()
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Required JS -->
    <script src="~/dashboard/js/plugins/popper.min.js"></script>
    <script src="~/dashboard/js/plugins/simplebar.min.js"></script>
    <script src="~/dashboard/js/plugins/bootstrap.min.js"></script>
    <script src="~/dashboard/js/config.js"></script>
    <script src="~/dashboard/js/pcoded.js"></script>
    <script>
        function syncTheme() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', theme);
            document.body.setAttribute('data-pc-theme', theme);
            
            if (theme === 'dark') {
                document.documentElement.style.setProperty('--bs-body-bg', '#293240');
                document.documentElement.style.setProperty('--bs-border-color', '#3b4452');
            } else {
                document.documentElement.style.setProperty('--bs-body-bg', '#fff');
                document.documentElement.style.setProperty('--bs-border-color', '#f3f3f3');
            }
        }

        window.addEventListener('load', function() {
            syncTheme();
            document.querySelector('.loader-bg').style.display = 'none';
        });

        window.addEventListener('storage', function(e) {
            if (e.key === 'theme') {
                syncTheme();
            }
        });
    </script>
</body>
</html> 