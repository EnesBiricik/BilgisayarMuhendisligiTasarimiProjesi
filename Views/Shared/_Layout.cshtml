@using System.Security.Claims
@using System.Text.Json
@{
    var userName = User?.Identity?.Name;
    var userRole = User?.FindFirst(ClaimTypes.Role)?.Value;
    var userEmail = User?.FindFirst(ClaimTypes.Email)?.Value;
    var message = TempData["success"] ?? TempData["error"] ?? TempData["info"] ?? TempData["warning"];
    var type = TempData["success"] != null ? "success" :
               TempData["error"] != null ? "danger" :
               TempData["info"] != null ? "info" :
               TempData["warning"] != null ? "warning" : null;
    var title = TempData["success"] != null ? "Başarılı!" :
                TempData["error"] != null ? "Hata!" :
                TempData["info"] != null ? "Bilgi!" :
                TempData["warning"] != null ? "Uyarı!" : null;
    var mailtoEmail = "info@esensoftware.com.tr";
    var mailtoSubject = "Destek Talebi , doganaydinayakkabi.com";
    var mailtoBody = "Merhaba, benimle iletişime geçin.";
}

<!doctype html>
<html lang="tr">
<!-- [Head] start -->

<head>
    <title>@ViewData["Title"]</title>
    
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=0,minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description"
          content="Bilgisayar Mühendisliği Yönetim Paneli - Profesyonel web çözümleri ve yazılım hizmetleri için özel olarak tasarlanmış yönetim arayüzü.">
    <meta name="keywords"
          content="yönetim paneli, admin panel, web yazılım, bilgisayar mühendisliği, kurumsal yazılım, özel yazılım çözümleri">
    <meta name="author" content="Bilgisayar Mühendisliği">
    <!-- [Favicon] icon -->
    <link rel="icon" href="~/dashboard/images/favicon.svg" type="image/x-icon"><!-- [Font] Family -->
    <link rel="stylesheet" href="~/dashboard/fonts/inter/inter.css" id="main-font-link">
    
    <!-- [phosphor Icons] https://phosphoricons.com/ -->
    <link rel="stylesheet" href="~/dashboard/fonts/phosphor/duotone/style.css">
    
    <!-- [Tabler Icons] https://tablericons.com -->
    <link rel="stylesheet" href="~/dashboard/fonts/tabler-icons.min.css"><!-- [Feather Icons] https://feathericons.com -->
    <link rel="stylesheet" href="~/dashboard/fonts/feather.css">
    <link rel="stylesheet" href="~/dashboard/css/plugins/notifier.css">
    
    <!-- [Font Awesome Icons] https://fontawesome.com/icons -->
    <link rel="stylesheet" href="~/dashboard/fonts/fontawesome.css">
    
    <!-- [Material Icons] https://fonts.google.com/icons -->
    <link rel="stylesheet" href="~/dashboard/fonts/material.css"><!-- [Template CSS Files] -->
    <link rel="stylesheet" href="~/dashboard/css/style.css" id="main-style-link">
    <script src="~/dashboard/js/tech-stack.js"></script>
    <link rel="stylesheet" href="~/dashboard/css/style-preset.css">

    <style>
        .loader-bg{
            background-color:"#ccc" !important,
            opacity:0.9 !important;
            filter:blur(3px) !important;
        }
        .img-fluid.logo-lg{
            width: 77px;
        }
        [data-pc-theme="dark"] .badge.bg-light-success{
            background: rgba(25, 135, 84, 0.484);
            color: #198754;
            border-color: rgba(25, 135, 84, 0.501);
            position: absolute;
            left: 66px;
            z-index: 100000;
            opacity: 1;
            top: 50px;
        }
        .dt-layout-row:not(.dt-layout-table) {
            display: flex;
            justify-content: space-between;
            padding: 1rem 0px;
        }

        .dt-layout-row:not(.dt-layout-table) .dt-layout-col-12 {
            width: 100%;
        }
    </style>

    @await RenderSectionAsync("links", required: false)
</head>
<!-- [Head] end -->


<!-- [Body] Start -->

<body data-pc-preset="preset-1" data-pc-sidebar-caption="true" data-pc-layout="vertical" data-pc-direction="ltr"
      data-pc-theme_contrast="" data-pc-theme="dark">
   
      <!-- [ Pre-loader ] start -->
    <div class="loader-bg">
        <div class="loader-track">
            <div class="loader-fill"></div>
        </div>
    </div><!-- [ Pre-loader ] End -->


    <!-- [ Sidebar Menu ] start -->
    <nav class="pc-sidebar">
        <div class="navbar-wrapper">
            <div class="m-header">
                @* <a href="/panel" *@
                @*    class="b-brand text-primary"> *@
                @*     <!-- ========   Change your logo from here   ============ -->  *@
                @*     <img src="~/dashboard/images/logo-dark.png" class="img-fluid logo-lg" alt="Bilgisayar Mühendisliği Logo">  *@
                @*     <span class="badge bg-light-success rounded-pill ms-2 theme-version">v1.0</span> *@
                @* </a> *@
            </div>
            <div class="navbar-content">
                <div class="card pc-user-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/dashboard/images/user/avatar-1.png" alt="user-image"
                                     class="user-avtar rounded-circle" style="width: 40px; height: 40px;">
                            </div>
                            <div class="flex-grow-1 ms-3 me-2">
                                <h6 class="mb-0" data-i18n="@userName">@userName</h6><small data-i18n="@userRole">@userRole</small>
                            </div><a class="btn btn-icon btn-link-secondary avtar" data-bs-toggle="collapse"
                                     href="#pc_sidebar_userlink">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-sort-outline"></use>
                                </svg>
                            </a>
                        </div>
                        <div class="collapse pc-user-links" id="pc_sidebar_userlink">
                            <div class="pt-3">
                                <a href="/User/AccountSettings">
                                    <i class="ti ti-user"></i> <span data-i18n="Hesap Ayarları">
                                        Hesap Ayarları
                                    </span>
                                </a><a href="/Auth/Logout">
                                    <i class="ti ti-power"></i> <span data-i18n="Çıkış Yap">Çıkış Yap</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <ul class="pc-navbar">
                    <li class="pc-item pc-caption">
                        <label data-i18n="Genel">Genel</label>
                        <svg class="pc-icon">
                            <use xlink:href="#custom-notification-status"></use>
                        </svg>
                    </li>
                    <li class="pc-item">
                        <a href="/panel" class="pc-link">
                            <span class="pc-micon">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-home"></use>
                                </svg>
                            </span><span class="pc-mtext" data-i18n="Anasayfa">Anasayfa</span>
                        </a>
                    </li>
                    <li class="pc-item">
                        <a href="/Panel/Statistics" class="pc-link">
                            <span class="pc-micon">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-status-up"></use>
                                </svg>
                            </span><span class="pc-mtext" data-i18n="İstatistikler">İstatistikler</span>
                        </a>
                    </li>
                    <li class="pc-item">
                        <a href="/Panel/Board" class="pc-link">
                            <span class="pc-micon">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-kanban"></use>
                                </svg>
                            </span><span class="pc-mtext" data-i18n="İş Panosu">İş Panosu</span>
                        </a>
                    </li>
                    <li class="pc-item pc-caption">
                        <label data-i18n="Ayarlar">Ayarlar</label>
                        <svg class="pc-icon">
                            <use xlink:href="#custom-setting-2"></use>
                        </svg>
                    </li>
                    <li class="pc-item">
                        <a href="/Settings/UpdateSettings" class="pc-link">
                            <span class="pc-micon">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-setting-outline"></use>
                                </svg>
                            </span><span class="pc-mtext" data-i18n="Site Ayarları">Site Ayarları</span>
                        </a>
                    </li>
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                    {
                         <li class="pc-item">
                        <a href="/User/List/" class="pc-link">
                            <span class="pc-micon">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-user-square"></use>
                                </svg>
                            </span><span class="pc-mtext" data-i18n="Kullanıcılar">Kullanıcılar</span>
                        </a>
                    </li>
                    }



                </ul>
            </div>
        </div>
    </nav>
    
    <!-- [ Sidebar Menu ] end -->


    <!-- [ Header Topbar ] start -->
    <header class="pc-header">
        <div class="header-wrapper">
            <!-- [Mobile Media Block] start -->
            <div class="me-auto pc-mob-drp">
                <ul class="list-unstyled">
                    <!-- ======= Menu collapse Icon ===== -->
                    <li class="pc-h-item pc-sidebar-collapse">
                        <a href="#" class="pc-head-link ms-0" id="sidebar-hide">
                            <i class="ti ti-menu-2"></i>
                        </a>
                    </li>
                    <li class="pc-h-item pc-sidebar-popup">
                        <a href="#" class="pc-head-link ms-0" id="mobile-collapse">
                            <i class="ti ti-menu-2"></i>
                        </a>
                    </li>
                    <li class="pc-h-item d-none d-md-inline-flex">
                        <form class="form-search position-relative">
                            <i class="search-icon">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-search-normal-1"></use>
                                </svg>
                            </i>
                            <input type="search" class="form-control" id="quickSearch" placeholder="Ara..." autocomplete="off">
                            <ul id="searchResults" class="dropdown-menu dropdown-menu-end w-100" style="margin-top: 5px; max-height: 300px; overflow-y: auto;">
                            </ul>
                        </form>
                    </li>
                </ul>
            </div>
            <!-- [Mobile Media Block end] -->
            <div class="ms-auto">
                <ul class="list-unstyled">
                    <li class="dropdown pc-h-item">
                        <a class="pc-head-link dropdown-toggle arrow-none me-0"
                           data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="false"
                           aria-expanded="false">
                            <svg class="pc-icon">
                                <use xlink:href="#custom-sun-1"></use>
                            </svg>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end pc-h-dropdown">
                            <a href="#!" class="dropdown-item"
                               onclick="applyTheme('dark')">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-moon"></use>
                                </svg> <span>Koyu</span>
                            </a><a href="#!" class="dropdown-item"
                                   onclick="applyTheme('light')">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-sun-1"></use>
                                </svg> <span>Açık</span>
                            </a>
                           @*  <a href="#!" class="dropdown-item"
                                   onclick="layout_change_default()">
                                <svg class="pc-icon">
                                    <use xlink:href="#custom-setting-2"></use>
                                </svg> <span>Default</span>
                            </a> *@
                        </div>
                    </li>
                    @* <li class="dropdown pc-h-item">
                        <a class="pc-head-link dropdown-toggle arrow-none me-0"
                           data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="false"
                           aria-expanded="false">
                            <svg class="pc-icon">
                                <use xlink:href="#custom-language"></use>
                            </svg>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end pc-h-dropdown lng-dropdown">
                            <a href="#!"
                               class="dropdown-item" data-lng="en"><span>English <small>(UK)</small> </span></a><a href="#!" class="dropdown-item" data-lng="fr">
                                <span>
                                    français <small>(French)</small>
                                </span>
                            </a><a href="#!" class="dropdown-item" data-lng="ro">
                                <span>
                                    Română
                                    <small>(Romanian)</small>
                                </span>
                            </a><a href="#!" class="dropdown-item"
                                   data-lng="cn"><span>中国人 <small>(Chinese)</small></span></a>
                        </div>
                    </li> *@
                    <li class="dropdown pc-h-item">
                        <a class="pc-head-link dropdown-toggle arrow-none me-0"
                           data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="false"
                           aria-expanded="false">
                            <svg class="pc-icon">
                                <use xlink:href="#custom-setting-2"></use>
                            </svg>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end pc-h-dropdown">
                            <a href="/User/AccountSettings" class="dropdown-item">
                                <i class="ti ti-user"></i> <span>Hesap Ayarları</span>
                            </a>
                            <a href="/Settings/UpdateSettings" class="dropdown-item"><i class="ti ti-settings"></i> <span>Ayarlar</span> </a>
                            <a href="mailto:@mailtoEmail?subject=@mailtoSubject&body=@mailtoBody" class="dropdown-item">
                                <i class="ti ti-headset"></i> <span>Destek</span>
                            </a>
                            <a href="/Auth/Logout" class="dropdown-item"><i class="ti ti-power"></i> <span>Çıkış Yap</span></a>
                        </div>
                    </li>
                    
                    
                    @await Component.InvokeAsync("PanelNotification")
                    
                    
                    <li class="dropdown pc-h-item header-user-profile">
                        <a class="pc-head-link dropdown-toggle arrow-none me-0" data-bs-toggle="dropdown" href="#"
                           role="button" aria-haspopup="false" data-bs-auto-close="outside" aria-expanded="false">
                            <img src="~/dashboard/images/user/avatar-1.png" alt="user-image" class="user-avtar">
                        </a>
                        <div class="dropdown-menu dropdown-user-profile dropdown-menu-end pc-h-dropdown">
                            <div class="dropdown-header d-flex align-items-center justify-content-between">
                                <h5 class="m-0">Profil</h5>
                            </div>
                            <div class="dropdown-body">
                                <div class="profile-notification-scroll position-relative"
                                     style="max-height: calc(100vh - 225px)">
                                    <div class="d-flex mb-3">
                                        <div class="flex-shrink-0">
                                            <img src="~/dashboard/images/user/avatar-1.png"
                                                 alt="user-image" class="user-avtar wid-35">
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="mb-1">@userName 🖖</h6><span>@userEmail</span>
                                        </div>
                                    </div>
                                    <hr class="border-secondary border-opacity-50">
                                    
                                    @* <hr class="border-secondary border-opacity-50">
                                    <div class="card">
                                        <div class="card-body py-3">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <h5 class="mb-0 d-inline-flex align-items-center">
                                                    <svg class="pc-icon text-muted me-2">
                                                        <use xlink:href="#custom-notification-outline"></use>
                                                    </svg>Notification
                                                </h5>
                                                <div class="form-check form-switch form-check-reverse m-0">
                                                    <input class="form-check-input f-18" type="checkbox" role="switch">
                                                </div>
                                            </div>
                                        </div>
                                    </div> *@
                                    <a href="/User/AccountSettings" class="dropdown-item">
                                        <span>
                                            <svg class="pc-icon text-muted me-2">
                                                <use xlink:href="#custom-setting-outline"></use>
                                            </svg> <span>Hesap Ayarları</span>
                                        </span>
                                    </a>
                                    <a href="/User/UpdatePassword" class="dropdown-item">
                                        <span>
                                            <svg class="pc-icon text-muted me-2">
                                                <use xlink:href="#custom-lock-outline"></use>
                                            </svg> <span>Şifre Değiştir</span>
                                        </span>
                                    </a>
                                    <hr class="border-secondary border-opacity-50">
                                    <div class="d-grid mb-3">
                                        <button class="btn btn-primary" onclick="window.location.href='/Auth/Logout'">
                                            <svg class="pc-icon me-2">
                                                <use xlink:href="#custom-logout-1-outline"></use>
                                            </svg>Çıkış Yap
                                        </button>
                                    </div>
                                    
                                </div>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </header>
    
    <!-- [ Header ] end -->

    <!-- [ Main Content ] start -->
    <div class="pc-container">
        <div class="pc-content">
            <div class="page-header">
                <div class="page-block">

                    <div class="row align-items-center">

                        @await RenderSectionAsync("breadcrumb", required: true)

                    </div>
                </div>
            </div>
            <div class="row">
                @RenderBody()
            </div><!-- [ Main Content ] end -->
        </div>
    </div>
    <!-- [ Main Content ] end -->

    <footer class="pc-footer">
        <div class="footer-wrapper container-fluid">
            <div class="row">
                <div class="col my-1">
                    <p class="m-0">
                        © @DateTime.Now.Year - <a href="https://bilgisayar-muhendisligi.com.tr"
                                                             target="_blank">Bilgisayar Mühendisliği</a> - Tüm hakları saklıdır. 
                                                             <span title="Musteri No"
                                                             class="text-muted">42-2026-NEU-7FDSA</span>
                    </p>
                </div>
                <div class="col-auto my-1">
                    <ul class="list-inline footer-link mb-0">
                        <li class="list-inline-item"><a target="_blank" href="/">Anasayfa</a></li>
                        <li class="list-inline-item">
                            <a href="mailto:@mailtoEmail?subject=@mailtoSubject&body=@mailtoBody">Destek</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>
    
    <!-- Required Js -->
    <script src="~/dashboard/js/plugins/popper.min.js"></script>
    <script src="~/dashboard/js/plugins/simplebar.min.js"></script>
    <script src="~/dashboard/js/plugins/bootstrap.min.js"></script>
    <script src="~/dashboard/js/plugins/i18next.min.js"></script>
    <script src="~/dashboard/js/plugins/i18nextHttpBackend.min.js"></script>
    <script src="~/dashboard/js/icon/custom-font.js"></script>
    <script src="~/dashboard/js/script.js"></script>
    <script src="~/dashboard/js/theme.js"></script>
    <script src="~/dashboard/js/multi-lang.js"></script>
    <script src="~/dashboard/js/plugins/feather.min.js"></script>
    <script src="~/dashboard/js/plugins/notifier.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <!-- Custom Js -->
    <script src="~/dashboard/js/search.js"></script>
    <script src="~/dashboard/js/theme-settings.js"></script>
    <script src="~/dashboard/js/form-validation.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var message = @Html.Raw(JsonSerializer.Serialize(message));
            var type = @Html.Raw(JsonSerializer.Serialize(type));
            var title = @Html.Raw(JsonSerializer.Serialize(title));

            if (message && type && title) {
                notifier.show(title, message, type, '', 2500);
            }
        });

       
    </script>
    @await RenderSectionAsync("scripts", required: false)
</body>

</html>