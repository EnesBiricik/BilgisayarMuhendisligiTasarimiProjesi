@using BilgisayarMuhendisligiTasarimi.Data.Entities
@model BilgisayarMuhendisligiTasarimi.Models.PanelIndexViewModel
@{
	ViewData["Title"] = "Panel";
	var percentageOfImage = Math.Max(2, Model.ImagesStorageMB * 100.0 / (Model.TotalStorageGB * 1024));
	var percentageOfMedia = Math.Max(2, Model.MediaStorageMB * 100.0 / (Model.TotalStorageGB * 1024));
	var percentageOfFiles = Math.Max(2, Model.FilesStorageMB * 100.0 / (Model.TotalStorageGB * 1024));
	var percentageOfOther = Math.Max(2, Model.OtherStorageMB * 100.0 / (Model.TotalStorageGB * 1024));
	var totalUsedPercentage = percentageOfImage + percentageOfMedia + percentageOfFiles + percentageOfOther;
	var remainingPercentage = Math.Max(2, 100 - totalUsedPercentage);
    var studioPrefix = string.Join("", Model.StudioName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(s => s[0])).ToUpper();
}

@section links {
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/apexcharts@3.41.0/dist/apexcharts.css">
    <link href="https://releases.transloadit.com/uppy/v3.18.1/uppy.min.css" rel="stylesheet">
}

@section breadcrumb {
	<div class="col-md-12">
		<ul class="breadcrumb">
			<li class="breadcrumb-item"><a href="/">Anasayfa</a></li>
			<li class="breadcrumb-item active">Panel</li>
		</ul>
	</div>
}

<div class="container-fluid">
    <div class="card welcome-banner bg-primary mb-4 p-0">
        <div class="card-body py-4 px-4 m-0 overflow-hidden">
            <div class="row align-items-center">
                <div class="col-sm-7">
                    <div class="p-2">
                        <h1 class="text-white fw-bold mb-2">@Model.StudioName Boards</h1>
                        <p class="text-white" style="font-size: 16px;">Stüdyonuzun dijital varlığını ve iş süreçlerini buradan yönetin.</p>
                    </div>
                </div>
                <div class="col-sm-5 text-center d-none d-sm-block text-end position-relative">
                    <img src="/dashboard/images/widget/welcome-banner.png" alt="img" class="img-fluid" style="max-height: 140px; margin-top:-20px; filter: drop-shadow(0px 10px 15px rgba(0,0,0,0.2));">
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card bg-dark-card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-transparent border-0 d-flex flex-wrap justify-content-between align-items-center py-3 gap-3">
                    <div class="d-flex align-items-center gap-4">
                        <h5 class="text-white mb-0">Görev Panosu</h5>
                        <ul class="nav nav-pills custom-nav-pills bg-dark-header p-1 rounded" id="taskTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active py-2 px-3" id="list-tab" data-bs-toggle="pill" data-bs-target="#listView" type="button" role="tab" aria-controls="listView" aria-selected="true">
                                    <i class="fas fa-list-ul me-2"></i>Liste
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link py-2 px-3" id="kanban-tab" data-bs-toggle="pill" data-bs-target="#kanbanView" type="button" role="tab" aria-controls="kanbanView" aria-selected="false">
                                    <i class="fas fa-columns me-2"></i>Kanban
                                </button>
                            </li>
                        </ul>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                            <i class="fas fa-plus me-2"></i>Yeni Görev
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="tab-content" id="taskTabContent">
                        
                        <div class="tab-pane fade show active" id="listView" role="tabpanel" aria-labelledby="list-tab">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead class="bg-dark-header">
                                        <tr>
                                            <th class="ps-4">BAŞLIK</th>
                                            <th>ÖNCELİK</th>
                                            <th>TİP</th>
                                            <th>SORUMLU</th>
                                            <th>DURUM</th>
                                            <th class="text-end pe-4">İŞLEMLER</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.RecentTasks != null && Model.RecentTasks.Any())
                                        {
                                            foreach (var task in Model.RecentTasks)
                                            {
                                                <tr>
                                                    <td class="ps-4 cursor-pointer" onclick="openTaskDetails(@task.Id)">
                                                        <div class="d-flex flex-column">
                                                            <span class="text-white fw-bold">@task.Title</span>
                                                            <small class="text-white-50">@task.CreateDate.ToString("dd MMM HH:mm")</small>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @switch (task.Priority)
                                                        {
                                                            case TaskPriorityEnum.Critical: <span class="badge bg-danger">Kritik</span> break;
                                                            case TaskPriorityEnum.High: <span class="badge bg-warning text-dark">Yüksek</span> break;
                                                            case TaskPriorityEnum.Medium: <span class="badge bg-info text-dark">Orta</span> break;
                                                            default: <span class="badge bg-secondary">Düşük</span> break;
                                                        }
                                                    </td>
                                                    <td><span class="text-white-50 small">@task.TaskType</span></td>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="avatar avatar-xs bg-light-primary text-primary me-2 f-10">
                                                                @(task.AssignedUser?.Name?[0].ToString() ?? "?")
                                                            </div>
                                                            <span class="text-white small">@(task.AssignedUser?.Name ?? "Atanmadı")</span>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        @switch (task.TaskStatus)
                                                        {
                                                            case TaskStatusEnum.Done: <span class="badge bg-success-soft text-success"><i class="fas fa-check me-1"></i> Bitti</span> break;
                                                            case TaskStatusEnum.InProgress: <span class="badge bg-primary-soft text-primary"><i class="fas fa-spinner fa-spin me-1"></i> Devam</span> break;
                                                            case TaskStatusEnum.Blocked: <span class="badge bg-danger-soft text-danger"><i class="fas fa-ban me-1"></i> Engel</span> break;
                                                            case TaskStatusEnum.InReview: <span class="badge bg-info-soft text-info"><i class="fas fa-search me-1"></i> İnceleme</span> break;
                                                            default: <span class="badge bg-secondary-soft text-muted"><i class="far fa-circle me-1"></i> Bekliyor</span> break;
                                                        }
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <button class="btn btn-sm btn-link-secondary text-muted p-1"><i class="fas fa-ellipsis-v"></i></button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="6" class="text-center py-5 text-muted fst-italic">Görev dosyası temiz! Yeni görev ekleyerek başlayın.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        
                        <div class="tab-pane fade" id="kanbanView" role="tabpanel" aria-labelledby="kanban-tab">
                            <div class="kanban-scroll-container p-4 overflow-auto">
                                <div class="d-flex gap-2" style="min-width: 1200px; justify-content: flex-start;">
                                    @foreach (var status in Enum.GetValues<TaskStatusEnum>())
                                    {
                                        var columnStyle = status switch {
                                            TaskStatusEnum.NotStarted => "background: rgba(133, 146, 163, 0.18); border-top: 6px solid #8592a3;",
                                            TaskStatusEnum.Blocked => "background: rgba(255, 182, 77, 0.18); border-top: 6px solid #ffb64d;",
                                            TaskStatusEnum.InProgress => "background: rgba(40, 167, 69, 0.22); border-top: 6px solid #28a745;",
                                            TaskStatusEnum.InReview => "background: rgba(63, 167, 236, 0.2); border-top: 6px solid #3fa7ec;",
                                            TaskStatusEnum.Done => "background: rgba(70, 128, 255, 0.18); border-top: 6px solid #4680ff;",
                                            _ => ""
                                        };
                                        <div class="kanban-column rounded-3 p-3" style="width: 19.5%; flex-shrink: 0; min-height: 500px; @columnStyle">
                                            <div class="column-header mb-4 d-flex justify-content-between align-items-center px-1">
                                                <div class="d-flex align-items-center gap-2">
                                                    <h6 class="text-uppercase fw-extrabold mb-0 small letter-spacing-2 theme-adaptive-text-bold">
                                                        @status.ToString().ToUpper()
                                                    </h6>
                                                    <span class="badge bg-secondary-soft text-dark-gray-adaptive rounded-pill board-count-badge">
                                                        @Model.AllTasks.Count(t => t.TaskStatus == status)
                                                    </span>
                                                </div>
                                                <button class="btn btn-xs btn-link-secondary p-0 text-muted" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                                                    <i class="fas fa-ellipsis-h"></i>
                                                </button>
                                            </div>
                                            <div class="kanban-cards d-flex flex-column gap-3 sortable-column" data-status="@((int)status)" style="min-height: 450px;">
                                                @foreach (var task in Model.AllTasks.Where(t => t.TaskStatus == status))
                                                {
                                                    <div class="card board-task-card rounded-2 shadow-sm border-0 cursor-pointer mb-0 priority-border-@task.Priority.ToString().ToLower()" data-id="@task.Id" onclick="openTaskDetails(@task.Id)">
                                                        <div class="card-body p-3">
                                                            <div class="mb-3">
                                                                <div class="d-flex align-items-center justify-content-between mb-2">
                                                                    <span class="text-muted extra-small fw-bold">@studioPrefix-@task.Id</span>
                                                                    <span class="badge @(task.Priority switch { TaskPriorityEnum.Critical => "bg-danger", TaskPriorityEnum.High => "bg-warning text-dark", TaskPriorityEnum.Medium => "bg-info text-dark", _ => "bg-secondary" }) fw-bold micro">@task.Priority.ToString().ToUpper()</span>
                                                                </div>
                                                                <h6 class="text-dark-adaptive mb-1 fw-bold line-clamp-2">@task.Title</h6>
                                                            </div>
                                                            <div class="d-flex justify-content-between align-items-center pt-2 border-top border-light-adaptive">
                                                                <div class="d-flex align-items-center">
                                                                    <div class="avatar avatar-xxs bg-light-primary text-primary me-2 f-8 fw-bold" style="width:20px; height:20px;">
                                                                        @(task.AssignedUser?.Name?[0].ToString() ?? "?")
                                                                    </div>
                                                                    <span class="text-muted tiny">@task.CreateDate.ToString("dd MMM")</span>
                                                                </div>
                                                                @if (task.Priority == TaskPriorityEnum.Critical || task.Priority == TaskPriorityEnum.High) {
                                                                    <i class="fas fa-clock text-warning tiny"></i>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary shadow-lg">
            <div class="modal-header border-secondary py-3">
                <div class="d-flex align-items-center gap-2">
                    <span id="detailTaskType" class="badge bg-primary-soft text-primary"></span>
                    <span id="detailTaskId" class="text-white-50 small fw-bold"></span>
                    <button type="button" class="btn btn-xs btn-outline-primary ms-3" id="editTaskBtn" onclick="toggleEditMode()">
                        <i class="fas fa-edit me-1"></i>Düzenle
                    </button>
                    <button type="button" class="btn btn-xs btn-success d-none" id="saveTaskBtn" onclick="saveTaskChanges()">
                        <i class="fas fa-save me-1"></i>Kaydet
                    </button>
                    <button type="button" class="btn btn-xs btn-link-secondary text-white-50 d-none" id="cancelEditBtn" onclick="toggleEditMode(false)">İptal</button>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body p-0">
                <div class="row g-0">
                    <div class="col-lg-8 p-4 border-end border-secondary">
                        <h4 id="detailTitle" class="text-white mb-4 fw-bold"></h4>
                        <div id="editTitleArea" class="mb-4 d-none">
                            <label class="text-white-50 small fw-bold mb-2 d-block text-uppercase">Başlık</label>
                            <input type="text" id="editTitleInput" class="form-control bg-dark border-secondary text-white">
                        </div>

                        <div class="mb-4">
                            <label class="text-white-50 small fw-bold mb-2 d-block text-uppercase">Açıklama</label>
                            <div id="detailDescription" class="text-white bg-dark-header p-3 rounded" style="min-height: 150px; line-height: 1.6;"></div>
                            <div id="editDescriptionArea" class="d-none">
                                <textarea id="editTaskEditor"></textarea>
                            </div>
                        </div>

                        <div class="mb-0">
                            <label class="text-white-50 small fw-bold mb-2 d-block text-uppercase">Dosyalar</label>
                            <div id="attachmentsList" class="d-flex flex-wrap gap-2 mb-3"></div>
                        </div>
                    </div>
                    <div class="col-lg-4 p-4">
                        <div class="mb-4">
                            <label class="text-white-50 small fw-bold mb-2 d-block text-uppercase">Durum</label>
                            <div id="detailStatus" class="d-inline-block"></div>
                            <select id="editStatusSelect" class="form-select bg-dark border-secondary text-white d-none">
                                @foreach (var s in Enum.GetValues<TaskStatusEnum>())
                                {
                                    <option value="@((int)s)">@s.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="text-white-50 small fw-bold mb-2 d-block text-uppercase">Öncelik</label>
                            <div id="detailPriority" class="d-inline-block"></div>
                            <select id="editPrioritySelect" class="form-select bg-dark border-secondary text-white d-none">
                                @foreach (var p in Enum.GetValues<TaskPriorityEnum>())
                                {
                                    <option value="@((int)p)">@p.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="text-white-50 small fw-bold mb-2 d-block text-uppercase">Tip</label>
                            <div id="detailTypeDisplay" class="text-white small mb-0"></div>
                            <select id="editTypeSelect" class="form-select bg-dark border-secondary text-white d-none">
                                @foreach (var t in Enum.GetValues<TaskTypeEnum>())
                                {
                                    <option value="@((int)t)">@t.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="row mb-4">
                            <div class="col-12">
                                <label class="text-white-50 extra-small fw-bold mb-1 d-block text-uppercase">Sorumlu</label>
                                <div id="detailAssigneeArea" class="d-flex align-items-center">
                                    <div id="detailAssigneeAvatar" class="avatar avatar-xs bg-light-primary text-primary me-2 f-10 fw-bold"></div>
                                    <span id="detailAssignee" class="text-white small"></span>
                                </div>
                                <select id="editAssigneeSelect" class="form-select bg-dark border-secondary text-white d-none mt-1">
                                    <option value="">Atanmadı</option>
                                    @foreach (var worker in Model.StudioWorkers)
                                    {
                                        <option value="@worker.Id">@worker.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                            <div class="col-6">
                                <label class="text-white-50 extra-small fw-bold mb-1 d-block text-uppercase">Oluşturan</label>
                                <div class="d-flex align-items-center">
                                    <span id="detailCreator" class="text-white small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-auto p-4 border-top border-secondary">
                            <div class="text-white-50 extra-small">
                                <i class="far fa-calendar-alt me-1"></i> Oluşturulma: <span id="detailCreateDate"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary shadow-lg">
            <div class="modal-header border-secondary py-3">
                <h5 class="modal-title text-white">Yeni Görev Oluştur</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <form id="createTaskForm" action="/Panel/CreateTask" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-white-50 small fw-bold text-uppercase">Başlık</label>
                        <input type="text" name="Title" class="form-control bg-dark border-secondary text-white" required placeholder="Görev başlığı...">
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label text-white-50 small fw-bold text-uppercase">Öncelik</label>
                            <select name="Priority" class="form-select bg-dark border-secondary text-white">
                                @foreach (var p in Enum.GetValues<TaskPriorityEnum>())
                                {
                                    <option value="@((int)p)">@p.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-white-50 small fw-bold text-uppercase">Tip</label>
                            <select name="TaskType" class="form-select bg-dark border-secondary text-white">
                                @foreach (var t in Enum.GetValues<TaskTypeEnum>())
                                {
                                    <option value="@((int)t)">@t.ToString()</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-white-50 small fw-bold text-uppercase">Sorumlu</label>
                            <select name="AssignedUserId" class="form-select bg-dark border-secondary text-white">
                                <option value="">Atanmadı</option>
                                @foreach (var worker in Model.StudioWorkers)
                                {
                                    <option value="@worker.Id">@worker.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50 small fw-bold text-uppercase">Dosyalar</label>
                        <input type="file" name="files" class="form-control bg-dark border-secondary text-white" multiple>
                    </div>
                    <div class="mb-0">
                        <label class="form-label text-white-50 small fw-bold text-uppercase d-block">Açıklama</label>
                        <textarea id="taskEditor" name="Description" class="form-control"></textarea>
                        <small class="text-danger editor-validation"></small>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-link-secondary text-white-50" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary px-4">Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="activityModal" tabindex="-1" aria-labelledby="activityModalLabel" aria-hidden="true">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="activityModalLabel">Aktivite Detayları</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
			</div>
			<div class="modal-body">
				<div class="mb-3">
					<label class="fw-bold">Kullanıcı Adı:</label>
					<p id="modalUsername" class="mb-2"></p>
				</div>
				<div class="mb-3">
					<label class="fw-bold">Giriş Tarihi:</label>
					<p id="modalLoginDate" class="mb-2"></p>
				</div>
				<div class="mb-3">
					<label class="fw-bold">IP Adresi:</label>
					<p id="modalIp" class="mb-2"></p>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
			</div>
		</div>
	</div>
</div>

@section scripts {
	<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.41.0/dist/apexcharts.min.js"></script>
    <style>
        .bg-light-gray-adaptive { background-color: #ebecf0; }
        [data-pc-theme="dark"] .bg-light-gray-adaptive { background-color: #10141d; }
        .theme-adaptive-text-bold { color: #5e6c84; }
        [data-pc-theme="dark"] .theme-adaptive-text-bold { color: #8993a4; }
        .text-dark-adaptive { color: #172b4d; }
        [data-pc-theme="dark"] .text-dark-adaptive { color: #ebecf0; }
        .text-dark-gray-adaptive { color: #5e6c84; }
        [data-pc-theme="dark"] .text-dark-gray-adaptive { color: #b3bac5; }
        .border-light-adaptive { border-color: #ebecf0 !important; }
        [data-pc-theme="dark"] .border-light-adaptive { border-color: #2c333f !important; }
        .hover-bg-light-adaptive:hover { background-color: rgba(9, 30, 66, 0.08); }
        [data-pc-theme="dark"] .hover-bg-light-adaptive:hover { background-color: rgba(255, 255, 255, 0.08); }
        .board-count-badge { padding: 2px 8px; font-weight: 600; font-size: 0.7rem; }
        .board-task-card { background: #fff; border-left: 3px solid transparent !important; }
        [data-pc-theme="dark"] .board-task-card { background: #1a212d; }
        .status-bg-done { background-color: #e3fcef !important; }
        [data-pc-theme="dark"] .status-bg-done { background-color: #0c2d1f !important; }
        .status-bg-blocked { background-color: #fff9db !important; }
        [data-pc-theme="dark"] .status-bg-blocked { background-color: #2d260c !important; }
        .letter-spacing-2 { letter-spacing: 0.05em; }
        .fw-extrabold { font-weight: 800; }
        .avatar-xxs { width: 18px; height: 18px; font-size: 8px; }
        .micro { font-size: 0.7rem; }
        .sortable-ghost { opacity: 0.5; transform: scale(0.95); }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script src="https://cdn.ckeditor.com/ckeditor5/36.0.1/classic/ckeditor.js"></script>
	<script>
        function addAttachmentToList(path, container) {
            const fileName = path.split('/').pop();
            const dotIndex = fileName.indexOf('_');
            const displayName = dotIndex > -1 ? fileName.substring(0, dotIndex) + fileName.substring(fileName.lastIndexOf('.')) : fileName;
            
            const html = `
                <div class="attachment-item bg-dark-header rounded p-2 d-flex align-items-center border border-secondary" style="min-width: 150px;">
                    <i class="fas fa-file-alt text-primary me-2"></i>
                    <div class="flex-grow-1 overflow-hidden">
                        <a href="${path}" target="_blank" class="text-white small d-block text-truncate">${displayName}</a>
                    </div>
                </div>`;
            container.insertAdjacentHTML('beforeend', html);
        }

        let currentTaskId = null;
        let detailTaskEditor;

        async function openTaskDetails(id) {
            currentTaskId = id;
            const studioPrefix = '@studioPrefix';
            try {
                toggleEditMode(false);
                const response = await fetch(`/Panel/GetTaskDetails/${id}`);
                const data = await response.json();
                
                document.getElementById('detailTitle').textContent = data.title;
                document.getElementById('editTitleInput').value = data.title;
                
                document.getElementById('detailDescription').innerHTML = data.description;
                if (detailTaskEditor) {
                    detailTaskEditor.setData(data.description);
                } else {
                    ClassicEditor.create(document.querySelector('#editTaskEditor'), {
                        toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote'],
                        language: 'tr'
                    }).then(editor => {
                        detailTaskEditor = editor;
                        detailTaskEditor.setData(data.description);
                    });
                }

                document.getElementById('detailTaskId').textContent = `${studioPrefix}-${data.id}`;
                document.getElementById('detailTaskType').textContent = data.typeName;
                document.getElementById('detailTypeDisplay').textContent = data.typeName;
                document.getElementById('editTypeSelect').value = data.type;
                
                document.getElementById('detailAssignee').textContent = data.assignedUser;
                document.getElementById('detailAssigneeAvatar').textContent = data.assignedUser[0];
                document.getElementById('editAssigneeSelect').value = data.assignedUserId || "";
                
                document.getElementById('detailCreator').textContent = data.creatorUser;
                document.getElementById('detailCreateDate').textContent = data.createDate;
                
                document.getElementById('editStatusSelect').value = data.status;
                document.getElementById('editPrioritySelect').value = data.priority;

                const attachmentsList = document.getElementById('attachmentsList');
                attachmentsList.innerHTML = '';
                if (data.attachments && data.attachments.length > 0) {
                    data.attachments.forEach(path => addAttachmentToList(path, attachmentsList));
                }
                
                const statusHtml = getStatusBadge(data.statusName);
                document.getElementById('detailStatus').innerHTML = statusHtml;
                
                const priorityHtml = getPriorityBadge(data.priorityName);
                document.getElementById('detailPriority').innerHTML = priorityHtml;
                
                new bootstrap.Modal(document.getElementById('taskDetailModal')).show();
            } catch (error) {
                console.error('Task detayı yüklenemedi:', error);
            }
        }

        function toggleEditMode(show = true) {
            const elements = {
                view: ['detailTitle', 'detailDescription', 'detailStatus', 'detailPriority', 'detailTypeDisplay', 'detailAssigneeArea', 'editTaskBtn'],
                edit: ['editTitleArea', 'editDescriptionArea', 'editStatusSelect', 'editPrioritySelect', 'editTypeSelect', 'editAssigneeSelect', 'saveTaskBtn', 'cancelEditBtn']
            };
            
            elements.view.forEach(id => document.getElementById(id).classList.toggle('d-none', show));
            elements.edit.forEach(id => document.getElementById(id).classList.toggle('d-none', !show));
        }

        async function saveTaskChanges() {
            if (!currentTaskId) return;
            
            const formData = new FormData();
            formData.append('Id', currentTaskId);
            formData.append('Title', document.getElementById('editTitleInput').value);
            formData.append('Description', detailTaskEditor.getData());
            formData.append('TaskStatus', document.getElementById('editStatusSelect').value);
            formData.append('Priority', document.getElementById('editPrioritySelect').value);
            formData.append('TaskType', document.getElementById('editTypeSelect').value);
            formData.append('AssignedUserId', document.getElementById('editAssigneeSelect').value);

            try {
                const response = await fetch('/Panel/UpdateTask', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    location.reload();
                }
            } catch (error) {
                console.error('Görev güncellenemedi:', error);
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const columns = document.querySelectorAll('.sortable-column');
            columns.forEach(column => {
                new Sortable(column, {
                    group: 'tasks',
                    animation: 150,
                    ghostClass: 'sortable-ghost',
                    onEnd: async function(evt) {
                        const taskId = evt.item.getAttribute('data-id');
                        const newStatus = evt.to.getAttribute('data-status');
                        
                        try {
                            const formData = new FormData();
                            formData.append('taskId', taskId);
                            formData.append('newStatus', newStatus);
                            
                            await fetch('/Panel/UpdateTaskStatus', {
                                method: 'POST',
                                body: formData
                            });
                        } catch (error) {
                            console.error('Durum güncellenemedi:', error);
                        }
                    }
                });
            });
        });

        function getStatusBadge(status) {
            switch(status) {
                case 'Done': return '<span class="badge bg-success-soft text-success"><i class="fas fa-check me-1"></i> Tamamlandı</span>';
                case 'InProgress': return '<span class="badge bg-primary-soft text-primary"><i class="fas fa-spinner fa-spin me-1"></i> Devam Ediyor</span>';
                case 'Blocked': return '<span class="badge bg-danger-soft text-danger"><i class="fas fa-ban me-1"></i> Engellendi</span>';
                default: return '<span class="badge bg-secondary-soft text-muted"><i class="far fa-circle me-1"></i> Bekliyor</span>';
            }
        }

        function getPriorityBadge(priority) {
            switch(priority) {
                case 'Critical': return '<span class="badge bg-danger">Kritik</span>';
                case 'High': return '<span class="badge bg-warning text-dark">Yüksek</span>';
                case 'Medium': return '<span class="badge bg-info text-dark">Orta</span>';
                default: return '<span class="badge bg-secondary">Düşük</span>';
            }
        }

        
        let taskEditor;
        ClassicEditor
            .create(document.querySelector('#taskEditor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote'],
                language: 'tr'
            })
            .then(newEditor => {
                taskEditor = newEditor;
            })
            .catch(error => {
                console.error(error);
            });

        
        document.getElementById('createTaskForm').addEventListener('submit', function(e) {
            if (taskEditor) {
                const data = taskEditor.getData();
                if (!data || data.trim() === '') {
                    document.querySelector('.editor-validation').textContent = 'Açıklama alanı zorunludur.';
                    e.preventDefault();
                    return false;
                }
                document.getElementById('taskEditor').value = data;
            }
            return true;
        });
	</script>
}

